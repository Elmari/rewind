# Atlassian PATs (on-prem)
JIRA_PAT=
CONFLUENCE_PAT=
BITBUCKET_PAT=

# GitLab PAT (on-prem)
GITLAB_PAT=

# GitHub PAT (github.com or Enterprise)
GITHUB_PAT=

# Jenkins API Token (NOT password)
JENKINS_TOKEN=

# Todoist API token (Settings → Integrations → Developer)
TODOIST_TOKEN=

# Gemini (corporate proxy)
GEMINI_API_KEY=

# Corporate proxy for HTTPS calls (Atlassian, Bitbucket, Gemini, Graph)
# HTTPS_PROXY=http://proxy.firma.de:8080
# HTTP_PROXY=http://proxy.firma.de:8080
# NO_PROXY=localhost,127.0.0.1

# Custom CA bundle (Node respects this automatically)
# NODE_EXTRA_CA_CERTS=C:/path/to/corp-ca-bundle.pem
