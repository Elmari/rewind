{
  "name": "rewind",
  "version": "0.1.0",
  "description": "Aggregates yesterday's activity from Jira, Confluence, Bitbucket, local git and Outlook, then summarizes it via Gemini for daily standup prep.",
  "type": "module",
  "bin": {
    "rewind": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "node --test --import tsx tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "husky && npm run build"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.0",
    "clipboardy": "^5.3.1",
    "commander": "^14.0.3",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.4.2",
    "js-yaml": "^4.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "simple-git": "^3.27.0",
    "undici": "^7.25.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.9.0",
    "husky": "^9.1.7",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
